---
import "../styles/global.css";

const {
  title = "Who Is Abebe?",
  description = "Public records investigation and entity mapping.",
} = Astro.props;
---

<html lang="en">

  <head>

    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width"
    />

    <title>{title}</title>

    <meta
      name="description"
      content={description}
    />

    <link
      rel="icon"
      type="image/png"
      href="/favicon.png"
    />

  </head>

  <body>

    <slot />

  </body>

</html>