---
import { readdirSync, statSync } from "node:fs";
import { basename, extname, join, relative } from "node:path";

import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const publicDir = join(process.cwd(), "public");
const scanRoots = ["docs", "filings", "images"];
const imageExtensions = new Set([".jpg", ".jpeg", ".png", ".webp", ".gif"]);
const pdfExtensions = new Set([".pdf"]);

const categoryOrder = [
  "People",
  "Project Images",
  "Property and Maps",
  "Website Screenshots",
  "Entity Records",
  "Article Images",
  "Source Documents and Letters",
  "PDFs",
  "Other Captures",
];

const peopleKeywords = [
  "headshot",
  "portrait",
  "interview",
  "mike-abebe",
  "mayor",
  "event-photo",
];

function walkFiles(dir) {
  return readdirSync(dir).flatMap((entry) => {
    const fullPath = join(dir, entry);
    const stat = statSync(fullPath);

    return stat.isDirectory() ? walkFiles(fullPath) : [fullPath];
  });
}

function toPublicPath(filePath) {
  return `/${relative(publicDir, filePath).replaceAll("\\", "/")}`;
}

function toTitle(filePath) {
  const extension = extname(filePath);
  return basename(filePath, extension)
    .replaceAll("-", " ")
    .replaceAll("_", " ")
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
}

function categorize(item) {
  const lowerPath = item.publicPath.toLowerCase();
  const lowerTitle = item.title.toLowerCase();

  if (item.kind === "PDF") {
    return "PDFs";
  }

  if (peopleKeywords.some((keyword) => lowerPath.includes(keyword) || lowerTitle.includes(keyword))) {
    return "People";
  }

  if (lowerPath.startsWith("/images/projects/")) {
    return "Project Images";
  }

  if (lowerPath.startsWith("/images/properties/") || lowerPath.startsWith("/images/maps/")) {
    return "Property and Maps";
  }

  if (lowerPath.startsWith("/images/websites/") || lowerPath.startsWith("/images/archived-sites/")) {
    return "Website Screenshots";
  }

  if (lowerPath.startsWith("/images/entities/")) {
    return "Entity Records";
  }

  if (lowerPath.startsWith("/images/articles/")) {
    return "Article Images";
  }

  if (lowerPath.startsWith("/docs/")) {
    return "Source Documents and Letters";
  }

  return "Other Captures";
}

const captures = scanRoots
  .flatMap((root) => walkFiles(join(publicDir, root)))
  .map((filePath) => {
    const extension = extname(filePath).toLowerCase();
    const publicPath = toPublicPath(filePath);
    const kind = imageExtensions.has(extension) ? "Image" : pdfExtensions.has(extension) ? "PDF" : "File";

    return {
      publicPath,
      extension,
      kind,
      title: toTitle(filePath),
    };
  })
  .filter((item) => item.kind === "Image" || item.kind === "PDF")
  .map((item) => ({
    ...item,
    category: categorize(item),
  }))
  .sort((a, b) => a.title.localeCompare(b.title));

const groupedCaptures = categoryOrder
  .map((category) => ({
    category,
    items: captures.filter((item) => item.category === category),
  }))
  .filter((group) => group.items.length > 0);

const imageCount = captures.filter((item) => item.kind === "Image").length;
const pdfCount = captures.filter((item) => item.kind === "PDF").length;
---

<BaseLayout title="Documents | Who Is Abebe?">

  <Header>
    <Fragment slot="title">Documents</Fragment>

    <Fragment slot="subtitle">
      Captured images, screenshots, PDFs, public records, and archived source material.
    </Fragment>
  </Header>

  <main class="article-wrap document-review-wrap">
    <article class="article-body document-review">

      <p class="lede">
        This page collects the source captures currently stored in the archive.
        Images open at full size for review, and PDFs open directly in the browser.
      </p>

      <div class="archive-summary" aria-label="Document archive summary">
        <div>
          <strong>{imageCount}</strong>
          <span>Images</span>
        </div>

        <div>
          <strong>{pdfCount}</strong>
          <span>PDFs</span>
        </div>

        <div>
          <strong>{captures.length}</strong>
          <span>Total Files</span>
        </div>
      </div>

      <nav class="archive-jump-links" aria-label="Document categories">
        {groupedCaptures.map((group) => (
          <a href={`#${group.category.toLowerCase().replaceAll(" ", "-")}`}>
            {group.category}
            <span>{group.items.length}</span>
          </a>
        ))}
      </nav>

      {groupedCaptures.map((group) => (
        <section id={group.category.toLowerCase().replaceAll(" ", "-")} class="capture-section">
          <h2>{group.category}</h2>

          <div class="capture-grid">
            {group.items.map((item) => (
              item.kind === "Image" ? (
                <button
                  class="capture-card capture-card-button"
                  type="button"
                  data-lightbox-src={item.publicPath}
                  data-lightbox-title={item.title}
                  data-lightbox-path={item.publicPath}
                >
                  <img src={item.publicPath} alt={item.title} loading="lazy" />

                  <div class="capture-card-body">
                    <span>{item.kind}</span>
                    <strong>{item.title}</strong>
                    <small>{item.publicPath}</small>
                  </div>
                </button>
              ) : (
              <a class="capture-card" href={item.publicPath} target="_blank" rel="noreferrer">
                {item.kind === "Image" ? (
                  <img src={item.publicPath} alt={item.title} loading="lazy" />
                ) : (
                  <div class="pdf-preview">
                    <span>PDF</span>
                  </div>
                )}

                <div class="capture-card-body">
                  <span>{item.kind}</span>
                  <strong>{item.title}</strong>
                  <small>{item.publicPath}</small>
                </div>
              </a>
              )
            ))}
          </div>
        </section>
      ))}

    </article>
  </main>

  <div class="image-lightbox" id="image-lightbox" aria-hidden="true">
    <button class="lightbox-backdrop" type="button" data-lightbox-close aria-label="Close image preview"></button>

    <figure class="lightbox-panel" role="dialog" aria-modal="true" aria-labelledby="lightbox-title">
      <button class="lightbox-close" type="button" data-lightbox-close aria-label="Close image preview">
        Close
      </button>

      <img id="lightbox-image" src="" alt="" />

      <figcaption>
        <strong id="lightbox-title"></strong>
        <span id="lightbox-path"></span>
      </figcaption>
    </figure>
  </div>

  <Footer />

</BaseLayout>

<script>
  const lightbox = document.querySelector("#image-lightbox");
  const lightboxImage = document.querySelector("#lightbox-image");
  const lightboxTitle = document.querySelector("#lightbox-title");
  const lightboxPath = document.querySelector("#lightbox-path");
  const imageButtons = document.querySelectorAll("[data-lightbox-src]");
  const closeButtons = document.querySelectorAll("[data-lightbox-close]");

  function closeLightbox() {
    if (!lightbox || !(lightboxImage instanceof HTMLImageElement)) return;

    lightbox.setAttribute("aria-hidden", "true");
    lightboxImage.src = "";
    lightboxImage.alt = "";
    document.body.classList.remove("lightbox-open");
  }

  imageButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (
        !lightbox ||
        !(lightboxImage instanceof HTMLImageElement) ||
        !lightboxTitle ||
        !lightboxPath
      ) return;

      const src = button.getAttribute("data-lightbox-src") || "";
      const title = button.getAttribute("data-lightbox-title") || "Image preview";
      const path = button.getAttribute("data-lightbox-path") || "";

      lightboxImage.src = src;
      lightboxImage.alt = title;
      lightboxTitle.textContent = title;
      lightboxPath.textContent = path;
      lightbox.setAttribute("aria-hidden", "false");
      document.body.classList.add("lightbox-open");
    });
  });

  closeButtons.forEach((button) => {
    button.addEventListener("click", closeLightbox);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeLightbox();
    }
  });
</script>

<style>
  .document-review {
    max-width: 1120px;
  }

  .archive-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin: 34px 0;
  }

  .archive-summary div {
    border: 1px solid var(--border);
    padding: 18px;
    background: #f7f7f7;
  }

  .archive-summary strong {
    display: block;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 2rem;
    line-height: 1;
  }

  .archive-summary span,
  .archive-jump-links a,
  .capture-card-body span,
  .capture-card-body small {
    font-family: Arial, Helvetica, sans-serif;
  }

  .archive-summary span {
    color: #555;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .archive-jump-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 30px 0 18px;
  }

  .archive-jump-links a {
    border: 1px solid var(--border);
    color: inherit;
    display: inline-flex;
    gap: 8px;
    padding: 9px 12px;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .archive-jump-links span {
    color: var(--red);
  }

  .capture-section {
    scroll-margin-top: 20px;
  }

  .capture-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 18px;
    margin: 26px 0 52px;
  }

  .capture-card {
    border: 1px solid var(--border);
    color: inherit;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    text-decoration: none;
    background: white;
  }

  .capture-card-button {
    cursor: zoom-in;
    font: inherit;
    padding: 0;
    text-align: left;
  }

  .capture-card:hover {
    border-color: #999;
  }

  .capture-card img,
  .pdf-preview {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #f2f2f2;
    border-bottom: 1px solid var(--border);
  }

  .capture-card img {
    display: block;
    object-fit: contain;
  }

  .pdf-preview {
    align-items: center;
    display: flex;
    justify-content: center;
  }

  .pdf-preview span {
    border: 3px solid var(--red);
    color: var(--red);
    font-family: Arial, Helvetica, sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 16px 18px;
  }

  .capture-card-body {
    display: grid;
    gap: 8px;
    padding: 16px;
  }

  .capture-card-body span {
    color: var(--red);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .capture-card-body strong {
    font-family: Arial, Helvetica, sans-serif;
    line-height: 1.25;
  }

  .capture-card-body small {
    color: #666;
    font-size: 0.76rem;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  .image-lightbox {
    align-items: center;
    display: none;
    inset: 0;
    justify-content: center;
    padding: 24px;
    position: fixed;
    z-index: 50;
  }

  .image-lightbox[aria-hidden="false"] {
    display: flex;
  }

  .lightbox-backdrop {
    background: rgba(0, 0, 0, 0.82);
    border: 0;
    cursor: zoom-out;
    inset: 0;
    padding: 0;
    position: absolute;
  }

  .lightbox-panel {
    background: #fff;
    margin: 0;
    max-height: min(88vh, 960px);
    max-width: min(92vw, 1180px);
    padding: 18px;
    position: relative;
    width: max-content;
    z-index: 1;
  }

  .lightbox-panel img {
    display: block;
    max-height: calc(88vh - 110px);
    max-width: calc(92vw - 36px);
    object-fit: contain;
  }

  .lightbox-panel figcaption {
    display: grid;
    gap: 6px;
    margin-top: 12px;
  }

  .lightbox-panel figcaption strong,
  .lightbox-panel figcaption span,
  .lightbox-close {
    font-family: Arial, Helvetica, sans-serif;
  }

  .lightbox-panel figcaption span {
    color: #666;
    font-size: 0.78rem;
    overflow-wrap: anywhere;
  }

  .lightbox-close {
    background: var(--black);
    border: 0;
    color: white;
    cursor: pointer;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 10px 12px;
    position: absolute;
    right: 18px;
    text-transform: uppercase;
    top: 18px;
    z-index: 2;
  }

  body.lightbox-open {
    overflow: hidden;
  }

  @media (max-width: 760px) {
    .archive-summary {
      grid-template-columns: 1fr;
    }

    .capture-grid {
      grid-template-columns: 1fr;
    }

    .image-lightbox {
      padding: 14px;
    }

    .lightbox-panel {
      max-width: 100%;
      padding: 12px;
      width: 100%;
    }

    .lightbox-panel img {
      max-height: calc(86vh - 120px);
      max-width: 100%;
      width: 100%;
    }
  }
</style>
