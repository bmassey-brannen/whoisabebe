---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import articles from "../data/articles.json";

const getDateTime = (date) => {
  const parsed = Date.parse(date);
  return Number.isNaN(parsed) ? Number.MAX_SAFE_INTEGER : parsed;
};

const reportingArticles = articles
  .sort((a, b) => getDateTime(a.publishedDate) - getDateTime(b.publishedDate));
---

<BaseLayout title="Who Is Abebe?">

  <Header>
    <Fragment slot="title">
      Who Is Abebe?
    </Fragment>

    <Fragment slot="subtitle">
      Public records. Local development. Open questions.
    </Fragment>

    <Fragment slot="media">
      <a class="hero-portrait-link" href="/reports/mike-abebe" aria-label="Read the Mike Abebe report">
        <img
          src="/images/entities/mike-abebe-portrait.jpg"
          alt="Mike Abebe portrait"
        />
        <span>Mike Abebe Report</span>
      </a>
    </Fragment>
  </Header>

  <main class="article-wrap">
    <article class="article-body">

      <p class="lede">
        This site organizes public records, meeting minutes, archived websites,
        local reporting, project renderings, and property documents connected
        to the St. George Crossing development in Waynesboro, Georgia.
      </p>

      <div class="notice-box">
        <strong>Methodology note:</strong>
        This archive is built from public records, public websites, local reporting,
        archived webpages, and documents collected for review. Claims are separated
        from observations wherever possible.
      </div>

      <h2>What This Archive Tracks</h2>

      <p>
        Who Is Abebe? is a working public-records archive focused on the people,
        companies, addresses, properties, websites, and municipal materials that
        appear around St. George Crossing and related development activity.
      </p>

      <div class="fact-grid">
        <div class="fact-card">
          <span>Reports</span>
          <p>
            Focused research files on St. George Crossing, Mike Abebe, Direct Invest,
            Elysian Development Group, and related records.
          </p>
        </div>

        <div class="fact-card">
          <span>Evidence</span>
          <p>
            Screenshots, renderings, archived webpages, public letters, meeting
            minutes, property captures, and source documents.
          </p>
        </div>

        <div class="fact-card">
          <span>Questions</span>
          <p>
            A structured place to separate what is documented, what is observed,
            and what still needs stronger source material.
          </p>
        </div>
      </div>

      <h2>Start Here</h2>

      <div class="section-grid">

        <a class="section-card feature-card" href="/reports">
          <span>Research Files</span>
          <h3>Reports</h3>
          <p>
            Longform public records reviews, including St. George Crossing,
            Mike Abebe, related entities, properties, and municipal documents.
          </p>
        </a>

        <a class="section-card" href="/documents">
          <span>Evidence Archive</span>
          <h3>Documents</h3>
          <p>
            PDFs, screenshots, renderings, filings, meeting minutes,
            public letters, and archived webpages.
          </p>
        </a>

        <a class="section-card" href="/projects">
          <span>Company Project Claims</span>
          <h3>Projects</h3>
          <p>
            Captured Abebe.com project pages, renderings, development claims,
            and snapshots for comparison against public records.
          </p>
        </a>

        <a class="section-card" href="/timeline">
          <span>Chronology</span>
          <h3>Timeline</h3>
          <p>
            A chronological reconstruction of articles, records,
            filings, project announcements, and public documents.
          </p>
        </a>

      </div>

      <h2>Local and Development Reporting</h2>

      <table class="report-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Article</th>
            <th>Source</th>
            <th>Author</th>
          </tr>
        </thead>

        <tbody>
          {reportingArticles.map((article) => (
            <tr>
              <td>{article.publishedDate}</td>
              <td>
                <a href={article.url} target="_blank">
                  {article.title}
                </a>
              </td>
              <td>{article.source}</td>
              <td>{article.author}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h2>Corrections</h2>

      <p>
        If any document, date, name, or description appears incorrect,
        corrections and additional source material are welcome.
      </p>

    </article>
  </main>

  <Footer />

</BaseLayout>
