---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

import projects from "../../data/projects.json";
---

<BaseLayout title="Projects | Who Is Abebe?">

  <Header>
    <Fragment slot="title">Projects</Fragment>

    <Fragment slot="subtitle">
      Captured Abebe.com development pages, renderings, claims, and project snapshots.
    </Fragment>
  </Header>

  <main class="article-wrap">
    <article class="article-body projects-page">

      <p class="lede">
        This page organizes the current Abebe.com development-project snapshots
        captured for the archive. These are company-published project materials
        and should be compared against property records, permits, zoning files,
        grant records, local reporting, and municipal documents.
      </p>

      <div class="notice-box">
        <strong>Archive note:</strong>
        These project pages can change. The screenshots below preserve what was
        visible in the current Abebe.com development menu at the time of capture.
      </div>

      <div class="project-snapshot-grid">
        {projects.map((project) => (
          <article class="project-snapshot-card" id={project.slug}>
            <a href={project.snapshotPath} target="_blank" rel="noreferrer">
              <img src={project.snapshotPath} alt={`${project.name} Abebe.com project snapshot`} loading="lazy" />
            </a>

            <div class="project-snapshot-body">
              <span>{project.category}</span>
              <h2>{project.name}</h2>
              <p>{project.location}</p>
              <small>{project.notes}</small>

              <div class="project-actions">
                <a href={project.snapshotPath} target="_blank" rel="noreferrer">Open Snapshot</a>
                {project.relatedReport && (
                  <a href={project.relatedReport}>Related Report</a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>

    </article>
  </main>

  <Footer />

</BaseLayout>

<style>
  .projects-page {
    max-width: 1180px;
  }

  .project-snapshot-grid {
    display: grid;
    gap: 28px;
    margin: 36px 0 72px;
  }

  .project-snapshot-card {
    border: 1px solid var(--border);
    display: grid;
    gap: 0;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    background: #fff;
  }

  .project-snapshot-card > a {
    background: #f3f3f3;
    border-right: 1px solid var(--border);
    display: block;
    min-height: 340px;
  }

  .project-snapshot-card img {
    display: block;
    height: 100%;
    max-height: 520px;
    object-fit: contain;
    width: 100%;
  }

  .project-snapshot-body {
    padding: 26px;
  }

  .project-snapshot-body span,
  .project-snapshot-body small,
  .project-actions a {
    font-family: Arial, Helvetica, sans-serif;
  }

  .project-snapshot-body span {
    color: var(--red);
    display: inline-block;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .project-snapshot-body h2 {
    margin-top: 0;
  }

  .project-snapshot-body small {
    color: #555;
    display: block;
    line-height: 1.5;
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .project-actions a {
    border: 1px solid #111;
    color: #111;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 9px 11px;
    text-decoration: none;
    text-transform: uppercase;
  }

  @media (max-width: 860px) {
    .project-snapshot-card {
      grid-template-columns: 1fr;
    }

    .project-snapshot-card > a {
      border-right: 0;
      border-bottom: 1px solid var(--border);
      min-height: 0;
    }

    .project-snapshot-card img {
      height: auto;
      max-height: none;
    }
  }
</style>
